# ===========================================
# BetterLife Server Environment Configuration
# ===========================================
# Copy this file to .env and update the values
# Do not commit .env to version control
# ===========================================
# Note: All variables use BETTERLIFE_ prefix
# and underscore notation (e.g., DATABASE_HOST)
# ===========================================

# Server Configuration
# --------------------
# Port the API server will listen on
BETTERLIFE_SERVER_PORT=8080

# Server mode: "debug" or "release"
# Use "debug" for development (verbose logging)
# Use "release" for production
BETTERLIFE_SERVER_MODE=debug

# Database Configuration (PostgreSQL)
# ------------------------------------
# Database host
BETTERLIFE_DATABASE_HOST=localhost

# Database port
BETTERLIFE_DATABASE_PORT=5432

# Database user
BETTERLIFE_DATABASE_USER=betterlife

# Database password
BETTERLIFE_DATABASE_PASSWORD=betterlife_dev

# Database name
BETTERLIFE_DATABASE_DBNAME=betterlife

# SSL mode: "disable", "require", "verify-ca", "verify-full"
# Use "disable" for local development
# Use "require" or higher for production
BETTERLIFE_DATABASE_SSLMODE=disable
